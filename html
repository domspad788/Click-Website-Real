<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="CLICK — A Capital Region digital services agency. Websites, ads, SEO, and social for local businesses in Upstate New York. Built to convert.">
<title>CLICK — Build. Scale. Win. | Digital Marketing Agency, Capital Region NY</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@200;300&family=DM+Mono:wght@400&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,700;1,9..144,300;1,9..144,500;1,9..144,700&family=Hanken+Grotesk:wght@300;400;500;600;700;800&family=Inter:wght@500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
/* =============================================================
   CLICK — Design System (Enhanced for Conversion)
   ============================================================= */
:root{
  --ink:#0E1B2C;
  --ink-2:#152437;
  --ink-3:#1D3047;
  --paper:#F6EFE3;
  --paper-2:#EBE2D2;
  --text:#1A2738;
  --text-muted:#6B7588;
  --text-inv:#F6EFE3;
  --text-inv-muted:#8DA0B8;
  --accent:#5B82B5;
  --accent-2:#FFB347;
  --accent-deep:#3D5F8F;
  --accent-glow:rgba(91,130,181,.35);
  --accent-rgb:91,130,181;
  --accent-cool:#5B82B5;
  --accent-cool-deep:#3D5F8F;
  --accent-cool-rgb:91,130,181;
  /* Secondary accents — used sparingly to differentiate live/growth, alerts, and premium content from the main blue brand color */
  --accent-green:#3ec97a;
  --accent-green-rgb:62,201,122;
  --accent-green-glow:rgba(62,201,122,.35);
  --accent-coral:#ff7a47;
  --accent-coral-rgb:255,122,71;
  --accent-coral-glow:rgba(255,122,71,.4);
  --accent-gold:#f5d765;
  --accent-gold-rgb:245,215,101;
  --accent-gold-glow:rgba(245,215,101,.45);
  --rule:rgba(26,39,56,.14);
  --rule-inv:rgba(246,239,227,.16);
  --f-display:'Fraunces',Georgia,serif;
  --f-body:'Hanken Grotesk',system-ui,-apple-system,sans-serif;
  --f-mono:'JetBrains Mono',ui-monospace,monospace;
  --max:1440px;
  --gutter:clamp(1.25rem,3.2vw,2.75rem);
  --radius:14px;
  --ease-out:cubic-bezier(.22,.9,.32,1);
  --ease-spring:cubic-bezier(.3,1.6,.5,1);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{
  font-family:var(--f-body);
  background:var(--ink);
  color:var(--text-inv);
  line-height:1.5;
  -webkit-font-smoothing:antialiased;
  -moz-osx-font-smoothing:grayscale;
  overflow-x:hidden;
  font-feature-settings:"ss01","cv11";
}
img,svg{display:block;max-width:100%}
a{color:inherit;text-decoration:none}
button{font:inherit;cursor:pointer;border:none;background:none;color:inherit}
::selection{background:var(--accent);color:var(--ink)}

/* Custom scrollbar */
::-webkit-scrollbar{width:10px;height:10px}
::-webkit-scrollbar-track{background:var(--ink)}
::-webkit-scrollbar-thumb{background:var(--ink-3);border-radius:5px}
::-webkit-scrollbar-thumb:hover{background:var(--accent-deep)}

/* Cursor follower */
.cursor-glow{
  position:fixed;width:400px;height:400px;border-radius:50%;
  background:radial-gradient(circle, rgba(var(--accent-rgb),.08), transparent 60%);
  pointer-events:none;z-index:1;
  transform:translate(-50%,-50%);
  transition:opacity .3s;mix-blend-mode:screen;
  will-change:transform;
}

.grain{
  position:fixed;inset:0;pointer-events:none;z-index:100;
  opacity:.04;mix-blend-mode:overlay;
  background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='180' height='180' viewBox='0 0 180 180'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
}

/* Scroll progress bar */
.scroll-progress{
  position:fixed;top:0;left:0;height:2px;
  background:linear-gradient(90deg, var(--accent), var(--accent-2));
  z-index:9998;width:0%;
  box-shadow:0 0 12px var(--accent);
  transition:width .1s;
}

/* (Site-wrapper has no default opacity rule — intro overlay sits on top until dismissed) */

/* =============================================================
   Nav (Enhanced)
   ============================================================= */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:200;
  padding:18px var(--gutter);
  background:var(--ink);
  color:var(--text-inv);
  border-bottom:1px solid var(--rule-inv);
  transition:padding .35s, box-shadow .35s;
}
.nav.scrolled{
  padding:12px var(--gutter);
  box-shadow:0 8px 24px rgba(0,0,0,.25);
}
.nav-inner{
  max-width:var(--max);margin:0 auto;
  display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:40px;
}
.brand{
  display:inline-flex;align-items:center;
  transition:transform .3s;
}
.brand:hover{transform:scale(1.05)}
.brand-mark{
  font-family:'Barlow Condensed',sans-serif;
  font-weight:200;
  font-style:normal;
  font-size:30px;
  letter-spacing:.04em;
  text-transform:uppercase;
  color:currentColor;
  display:inline-flex;align-items:center;
  line-height:1;
}
.brand-i-wrap{
  position:relative;display:inline-block;line-height:1;
}
.brand-i{
  display:inline-block;line-height:1;
  -webkit-mask-image:linear-gradient(to bottom,transparent 0%,transparent 42%,black 43%);
  mask-image:linear-gradient(to bottom,transparent 0%,transparent 42%,black 43%);
}
.brand-cursor{
  position:absolute;left:50%;top:22%;
  transform:translate(-50%,-50%);
  width:60%;height:45%;
  color:#fff;
  pointer-events:none;
  filter:drop-shadow(0 0 4px rgba(255,255,255,.6));
  animation:brand-cursor-bob 3s ease-in-out infinite;
}
.brand-cursor svg{width:100%;height:100%;display:block;transform:translateX(10%)}
@keyframes brand-cursor-bob{
  0%,100%{transform:translate(-50%,-50%) translateY(0)}
  50%{transform:translate(-50%,-50%) translateY(-1px)}
}
.foot-brand .brand-mark{font-size:44px}
.nav-links{
  display:flex;gap:2px;justify-content:flex-end;
  font-size:14px;
}
.nav-item{position:relative}
.nav-link{
  padding:10px 16px;border-radius:999px;
  color:inherit;opacity:.88;
  display:inline-flex;align-items:center;gap:6px;
  transition:opacity .2s,background .2s;
  background:transparent;
  font-weight:400;
}
.nav-link:hover{opacity:1;background:rgba(244,241,234,.07)}
.nav.light .nav-link:hover{background:rgba(15,15,16,.06)}
.nav-link .caret{
  width:10px;height:10px;
  transition:transform .25s;
  opacity:.6;
}
.nav-item:hover .caret{transform:rotate(180deg);opacity:1}

.dropdown{
  position:absolute;top:calc(100% + 14px);left:50%;
  transform:translateX(-50%) translateY(-8px);
  background:var(--ink);
  border:1px solid var(--rule-inv);
  border-radius:16px;
  padding:22px;
  min-width:640px;
  opacity:0;visibility:hidden;pointer-events:none;
  transition:opacity .25s, visibility .25s, transform .25s;
  box-shadow:0 30px 80px rgba(0,0,0,.5), 0 0 0 1px var(--rule-inv), 0 0 60px rgba(var(--accent-rgb),.06);
  z-index:50;
}
.nav-item:hover .dropdown{
  opacity:1;visibility:visible;pointer-events:auto;
  transform:translateX(-50%) translateY(0);
}
.nav-item::after{
  content:"";position:absolute;
  left:0;right:0;top:100%;height:16px;
}
.dropdown.wide{min-width:780px}
.dropdown.narrow{min-width:320px;left:auto;right:0;transform:translateX(0) translateY(-8px)}
.nav-item:hover .dropdown.narrow{transform:translateX(0) translateY(0)}
.dd-grid{display:grid;gap:24px}
.dd-grid.c3{grid-template-columns:repeat(3,1fr)}
.dd-grid.c2{grid-template-columns:repeat(2,1fr)}
.dd-col-label{
  font-family:var(--f-mono);font-size:10.5px;
  letter-spacing:.2em;text-transform:uppercase;
  color:var(--accent);margin-bottom:10px;
  padding-bottom:10px;border-bottom:1px solid var(--rule-inv);
}
.dd-item{
  display:flex;justify-content:space-between;align-items:center;gap:18px;
  padding:9px 10px;border-radius:8px;
  color:var(--text-inv);
  transition:background .15s, padding .2s;
  font-size:13.5px;
}
.dd-item:hover{background:rgba(var(--accent-rgb),.08);padding-left:14px}
@media (hover:none),(pointer:coarse){
  .dd-item:hover{background:transparent;padding-left:10px}
  .dd-item:active{background:rgba(var(--accent-rgb),.12)}
  .dd-item:hover .dd-price{color:var(--text-inv-muted)}
}
.dd-item .dd-name{font-weight:500}
.dd-item .dd-price{
  font-family:var(--f-mono);font-size:11px;
  letter-spacing:.04em;color:rgba(var(--accent-gold-rgb),.65);
  white-space:nowrap;
}
.dd-item:hover .dd-price{color:var(--accent-gold)}
.dd-cta{
  margin-top:16px;padding-top:14px;border-top:1px solid var(--rule-inv);
  display:flex;justify-content:space-between;align-items:center;
  font-family:var(--f-mono);font-size:11px;
  letter-spacing:.14em;text-transform:uppercase;
  color:var(--text-inv-muted);
}
.dd-cta a{color:var(--accent);transition:opacity .2s}
.dd-cta a:hover{opacity:.8}

.nav-cta{
  font-size:13px;font-weight:600;
  padding:11px 20px;border-radius:999px;
  background:var(--accent);color:var(--ink);
  display:inline-flex;align-items:center;gap:8px;
  transition:transform .2s, box-shadow .3s;
  position:relative;overflow:hidden;
}
.nav-cta::before{
  content:"";position:absolute;inset:0;
  background:linear-gradient(120deg, transparent 30%, rgba(255,255,255,.5) 50%, transparent 70%);
  transform:translateX(-100%);
  transition:transform .6s;
}
.nav-cta:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(var(--accent-rgb),.4)}
.nav-cta:hover::before{transform:translateX(100%)}
.nav-cta span{transition:transform .3s;position:relative;z-index:1}
.nav-cta:hover span{transform:translateX(3px)}
.nav-cta > *:not(::before){position:relative;z-index:1}

.nav-burger{
  display:none;padding:10px;border-radius:8px;
  width:40px;height:40px;
  flex-direction:column;justify-content:center;gap:4px;
  background:transparent;
}
.nav-burger span{
  display:block;height:1.5px;background:currentColor;
  transition:transform .3s, opacity .3s;
}
.nav-burger.open span:nth-child(1){transform:translateY(5.5px) rotate(45deg)}
.nav-burger.open span:nth-child(2){opacity:0}
.nav-burger.open span:nth-child(3){transform:translateY(-5.5px) rotate(-45deg)}

@media (max-width:1020px){
  .nav-links{
    position:fixed;top:74px;left:var(--gutter);right:var(--gutter);
    flex-direction:column;gap:6px;
    background:var(--ink);border:1px solid var(--rule-inv);border-radius:16px;
    padding:16px;
    max-height:calc(100svh - 100px);
    max-height:calc(100dvh - 100px);
    overflow-y:auto;
    -webkit-overflow-scrolling:touch;
    overscroll-behavior:contain;
    opacity:0;visibility:hidden;pointer-events:none;
    transform:translateY(-10px);transition:all .3s;
    box-shadow:0 20px 60px rgba(0,0,0,.5);
  }
  .nav-links.open{opacity:1;visibility:visible;pointer-events:auto;transform:translateY(0)}
  .nav-item{width:100%}
  .nav-link{width:100%;justify-content:space-between;padding:12px 14px;color:var(--text-inv)}
  .nav.light .nav-link{color:var(--text-inv)}
  .dropdown{
    position:static;min-width:0;width:100%;
    padding:6px 4px 4px;margin-top:2px;
    background:transparent;border:none;box-shadow:none;
    opacity:1;visibility:visible;pointer-events:auto;transform:none;
    display:none;
  }
  .nav-item.mob-open .dropdown{display:block}
  .nav-item::after{display:none}
  .dd-grid{gap:14px}
  .dd-grid.c3,.dd-grid.c2{grid-template-columns:1fr}
  .dd-col-label{margin-bottom:6px;padding-bottom:6px}
  .dd-item{padding:10px 10px;font-size:14px;gap:12px}
  .dd-item .dd-price{font-size:10.5px}
  .dd-item:hover{padding-left:10px}
  .dd-cta{
    flex-direction:column;align-items:flex-start;gap:6px;
    padding-top:12px;margin-top:12px;
  }
  .nav-burger{display:flex}
}

/* =============================================================
   Section shared
   ============================================================= */
section{position:relative}
.section{padding:clamp(88px,12vw,160px) var(--gutter);position:relative}
.section-inner{max-width:var(--max);margin:0 auto;position:relative}
.section-tag{
  font-family:var(--f-mono);font-size:11px;letter-spacing:.2em;text-transform:uppercase;
  color:var(--text-muted);
  display:inline-flex;align-items:center;gap:10px;margin-bottom:28px;
}
.section-tag::before{
  content:"";width:6px;height:6px;border-radius:50%;
  background:var(--accent);display:inline-block;
  box-shadow:0 0 8px var(--accent);
  animation:tag-blink 2s ease-in-out infinite;
}
/* Rotate accent colors across sections — only the tag dot changes, brand stays blue */
.bundles .section-tag::before{background:var(--accent-gold);box-shadow:0 0 8px var(--accent-gold-glow)}
.region-section .section-tag::before,
[id="coverage"] .section-tag::before{background:var(--accent-gold);box-shadow:0 0 8px var(--accent-gold-glow)}
.showcase .section-tag::before{background:var(--accent-green);box-shadow:0 0 8px var(--accent-green-glow)}
#partners .section-tag::before,
.about .section-tag::before{background:var(--accent-coral);box-shadow:0 0 8px var(--accent-coral-glow)}
@keyframes tag-blink{50%{opacity:.5}}
.section.dark .section-tag{color:var(--text-inv-muted)}
.section-title{
  font-family:var(--f-display);font-weight:400;
  font-size:clamp(40px,6.5vw,84px);
  line-height:1.02;letter-spacing:-.025em;
  max-width:18ch;color:var(--text);
}
.section.dark .section-title, .section-title.light{color:var(--text-inv)}
.section-title em{font-style:italic;font-weight:500}
.section-title .accent{color:var(--accent);font-style:italic;font-weight:500}
.section-sub{
  font-size:clamp(16px,1.4vw,19px);line-height:1.55;
  color:var(--text-muted);max-width:52ch;margin-top:24px;
}
.section.dark .section-sub, .section-sub.light{color:var(--text-inv-muted)}

/* =============================================================
   Hero (Enhanced with floating elements)
   ============================================================= */
.hero{
  background:var(--ink);
  min-height:100svh;
  padding:140px var(--gutter) 0;
  display:flex;flex-direction:column;position:relative;overflow:hidden;
}
.hero::before{
  content:"";position:absolute;inset:0;
  background:
    radial-gradient(900px 500px at 85% 20%, rgba(var(--accent-rgb),.1), transparent 55%),
    radial-gradient(700px 400px at 10% 85%, rgba(91,130,181,.05), transparent 60%);
  pointer-events:none;
}
.hero::after{
  content:"";position:absolute;inset:0;
  background:
    radial-gradient(ellipse 90% 70% at 50% 50%, transparent 30%, rgba(0,0,0,.55) 75%, rgba(0,0,0,.95) 100%),
    linear-gradient(180deg, rgba(0,0,0,.6) 0%, transparent 22%, transparent 78%, rgba(0,0,0,.65) 100%),
    linear-gradient(90deg, rgba(0,0,0,.5) 0%, transparent 12%, transparent 88%, rgba(0,0,0,.5) 100%);
  pointer-events:none;
  z-index:1;
}
/* Floating orbs */
.orb{
  position:absolute;border-radius:50%;
  pointer-events:none;filter:blur(60px);
  animation:orb-float 20s ease-in-out infinite;
}
.orb-1{width:300px;height:300px;background:rgba(var(--accent-rgb),.15);top:15%;right:10%}
.orb-2{width:250px;height:250px;background:rgba(91,130,181,.08);bottom:20%;left:5%;animation-delay:-7s}
.orb-3{width:200px;height:200px;background:rgba(var(--accent-rgb),.08);top:50%;left:40%;animation-delay:-14s}
@keyframes orb-float{
  0%,100%{transform:translate(0,0) scale(1)}
  33%{transform:translate(40px,-40px) scale(1.1)}
  66%{transform:translate(-30px,30px) scale(.9)}
}

.hero-inner{
  position:relative;max-width:var(--max);margin:0 auto;width:100%;
  flex:1;display:grid;
  grid-template-columns:minmax(0,1.05fr) minmax(0,.95fr);
  gap:60px;align-items:center;
  padding:40px 0 80px;z-index:2;
}
.hero-content{display:flex;flex-direction:column;justify-content:center;min-width:0}
@media (max-width:980px){
  .hero-inner{grid-template-columns:1fr;gap:48px}
  .hero-visual{margin-top:8px}
}

/* === Hero visual: dashboard mockup + floating chips === */
.hero-visual{
  position:relative;
  min-height:480px;
  perspective:1400px;
  transform-style:preserve-3d;
}
.dash-card{
  background:var(--ink-2);
  border:1px solid var(--rule-inv);
  border-radius:var(--radius);
  box-shadow:0 30px 70px rgba(0,0,0,.45), 0 0 0 1px rgba(255,255,255,.03) inset;
}
.dash-main{
  position:relative;z-index:2;
  width:100%;max-width:480px;margin-left:auto;
  transform:rotateY(-6deg) rotateX(3deg);
  transform-style:preserve-3d;
  transform-origin:center;
  animation:dash-bob 7s ease-in-out infinite;
}
@keyframes dash-bob{
  0%,100%{transform:rotateY(-6deg) rotateX(3deg) translateY(0)}
  50%{transform:rotateY(-4deg) rotateX(2deg) translateY(-8px)}
}
.dash-head{
  display:flex;align-items:center;gap:12px;
  padding:12px 16px;
  border-bottom:1px solid var(--rule-inv);
}
.dash-dots{display:inline-flex;gap:6px}
.dash-dots i{
  display:block;width:9px;height:9px;border-radius:50%;
  background:rgba(246,239,227,.18);
}
.dash-dots i:nth-child(1){background:#FF6B6B}
.dash-dots i:nth-child(2){background:#FFD93D}
.dash-dots i:nth-child(3){background:#6BCB77}
.dash-url{
  flex:1;text-align:center;
  font-family:var(--f-mono);font-size:11px;
  letter-spacing:.08em;color:var(--text-inv-muted);
  padding:5px 12px;border-radius:6px;
  background:rgba(0,0,0,.25);
  border:1px solid var(--rule-inv);
}
.dash-body{padding:18px 18px 20px;display:flex;flex-direction:column;gap:16px}
.dash-stat-label{
  font-family:var(--f-mono);font-size:10px;letter-spacing:.18em;
  text-transform:uppercase;color:var(--text-inv-muted);
}
.dash-stat-row{display:flex;align-items:baseline;gap:10px;margin-top:6px}
.dash-stat-num{
  font-family:var(--f-display);font-weight:400;
  font-size:36px;letter-spacing:-.02em;color:var(--text-inv);line-height:1;
}
.dash-trend{
  font-family:var(--f-mono);font-size:11px;font-weight:500;
  padding:3px 8px;border-radius:999px;
  letter-spacing:.04em;
}
.dash-trend.up{
  background:rgba(107,203,119,.15);color:#88E396;
}
.dash-chart{
  position:relative;
  display:flex;align-items:flex-end;gap:6px;height:90px;
  padding:10px 0;border-top:1px solid var(--rule-inv);
  border-bottom:1px solid var(--rule-inv);
}
.dash-chart > span{
  flex:1;background:linear-gradient(180deg,var(--accent),var(--accent-deep));
  border-radius:3px 3px 1px 1px;
  height:0;
  animation:dash-bar-grow 1.2s var(--ease-out) forwards;
  animation-delay:calc(var(--i,0) * 90ms);
  opacity:.55;
}
.dash-chart > span:nth-child(1){--i:0;opacity:.4}
.dash-chart > span:nth-child(2){--i:1;opacity:.45}
.dash-chart > span:nth-child(3){--i:2;opacity:.5}
.dash-chart > span:nth-child(4){--i:3;opacity:.55}
.dash-chart > span:nth-child(5){--i:4;opacity:.62}
.dash-chart > span:nth-child(6){--i:5;opacity:.7}
.dash-chart > span:nth-child(7){--i:6;opacity:.78}
.dash-chart > span:nth-child(8){--i:7;opacity:.86}
.dash-chart > span:nth-child(9){--i:8;opacity:.94}
.dash-chart > span:nth-child(10){
  --i:9;opacity:1;
  background:linear-gradient(180deg,var(--accent),var(--accent-deep));
  box-shadow:0 0 14px var(--accent-glow), inset 0 1px 0 rgba(255,255,255,.25);
  position:relative;
}
.dash-chart > span:nth-child(10)::after{
  content:"+24%";
  position:absolute;top:-18px;left:50%;transform:translateX(-50%);
  font-family:var(--f-mono);font-size:9px;font-weight:600;letter-spacing:.04em;
  color:var(--accent);
  opacity:0;animation:dash-pop-in .5s 1.6s var(--ease-spring) forwards;
  white-space:nowrap;
}
@keyframes dash-pop-in{from{opacity:0;transform:translate(-50%,4px) scale(.8)}to{opacity:1;transform:translate(-50%,0) scale(1)}}
@keyframes dash-bar-grow{to{height:var(--h)}}
.dash-chart-line{
  position:absolute;inset:10px 0;
  width:100%;height:calc(100% - 20px);
  pointer-events:none;overflow:visible;
}
.dash-line-area{opacity:0;animation:dash-line-fade 1.4s 1.6s ease forwards}
.dash-line-stroke{
