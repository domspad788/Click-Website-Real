  color:var(--text-inv-muted);opacity:.55;
}
.form-field input:hover,
.form-field select:hover,
.form-field textarea:hover{
  border-color:rgba(var(--accent-rgb),.35);
  background:rgba(244,241,234,.06);
}
.form-field input:focus,
.form-field select:focus,
.form-field textarea:focus{
  outline:none;
  border-color:var(--accent);
  background:rgba(var(--accent-rgb),.04);
  box-shadow:0 0 0 3px rgba(var(--accent-rgb),.18);
}
.form-field textarea{resize:vertical;min-height:120px;font-family:var(--f-body)}
.form-field select{
  cursor:pointer;
  background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 8' fill='none' stroke='%238DA0B8' stroke-width='1.5'><path d='M1 1.5L6 6.5L11 1.5'/></svg>");
  background-repeat:no-repeat;
  background-position:right 16px center;
  background-size:12px 8px;
  padding-right:44px;
}
.form-field select option{background:var(--ink-2);color:var(--text-inv)}
.form-field input:invalid:not(:placeholder-shown),
.form-field textarea:invalid:not(:placeholder-shown){
  border-color:rgba(255,107,74,.55);
}
.form-submit-row{
  display:flex;align-items:center;gap:24px;flex-wrap:wrap;
  margin-top:8px;
}
.form-submit-btn{
  position:relative;min-width:240px;justify-content:center;
  cursor:pointer;border:none;
  animation:submit-pulse 2.4s ease-in-out infinite;
}
@keyframes submit-pulse{
  0%,100%{box-shadow:0 4px 0 var(--accent-deep),0 8px 24px rgba(var(--accent-rgb),.18),0 0 0 0 rgba(var(--accent-rgb),.5)}
  50%{box-shadow:0 4px 0 var(--accent-deep),0 8px 28px rgba(var(--accent-rgb),.35),0 0 0 8px rgba(var(--accent-rgb),0)}
}
.form-submit-btn:hover{animation:none}
.form-submit-btn[disabled]{opacity:.7;cursor:wait}
.form-submit-loading{display:none}
.form-submit-btn[data-loading="true"] .form-submit-label{display:none}
.form-submit-btn[data-loading="true"] .form-submit-loading{display:inline}
.form-fineprint{
  font-family:var(--f-mono);font-size:11px;letter-spacing:.06em;
  color:var(--text-inv-muted);line-height:1.6;flex:1;min-width:240px;
}
.form-fineprint a{color:var(--accent);border-bottom:1px solid rgba(var(--accent-rgb),.3);transition:border-color .2s}
.form-fineprint a:hover{border-bottom-color:var(--accent)}
.form-error{
  margin-top:4px;padding:14px 16px;border-radius:10px;
  background:rgba(255,107,74,.1);border:1px solid rgba(255,107,74,.35);
  color:#FFB29A;font-size:14px;line-height:1.5;
}
.form-error[hidden]{display:none}
.form-error a{color:#FFB29A;text-decoration:underline}
