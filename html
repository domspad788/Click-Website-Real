.service.s-ads .svc-name em{color:var(--accent-coral)}
.service.s-ads::after{background:linear-gradient(90deg,var(--accent-coral),#c8543a)}
/* SEO → green */
.service.s-seo .svc-stage svg{stroke:var(--accent-green)}
.service.s-seo .svc-name em{color:var(--accent-green)}
.service.s-seo::after{background:linear-gradient(90deg,var(--accent-green),#2a9c5d)}
/* E-Commerce → gold */
.service.s-ecommerce .svc-stage svg{stroke:#c9a035}
.service.s-ecommerce .svc-name em{color:#c9a035}
.service.s-ecommerce::after{background:linear-gradient(90deg,var(--accent-gold),#c9a035)}
/* Social → coral */
.service.s-social .svc-stage svg{stroke:var(--accent-coral)}
.service.s-social .svc-stage svg [fill="currentColor"]{fill:var(--accent-coral)}
.service.s-social .svc-name em{color:var(--accent-coral)}
.service.s-social::after{background:linear-gradient(90deg,var(--accent-coral),#c8543a)}
/* Content → green */
.service.s-content .svc-stage svg{stroke:var(--accent-green)}
.service.s-content .svc-name em{color:var(--accent-green)}
.service.s-content::after{background:linear-gradient(90deg,var(--accent-green),#2a9c5d)}
/* Email → blue */
.service.s-email .svc-stage svg{stroke:var(--accent)}
.service.s-email .svc-name em{color:var(--accent)}
.service.s-email::after{background:linear-gradient(90deg,var(--accent),var(--accent-deep))}
/* Media → gold */
.service.s-media .svc-stage svg{stroke:#c9a035}
.service.s-media .svc-name em{color:#c9a035}
.service.s-media::after{background:linear-gradient(90deg,var(--accent-gold),#c9a035)}
/* Maintenance → green */
.service.s-maintenance .svc-stage svg{stroke:var(--accent-green)}
.service.s-maintenance .svc-name em{color:var(--accent-green)}
.service.s-maintenance::after{background:linear-gradient(90deg,var(--accent-green),#2a9c5d)}

/* Filter chip numbers rotate through the same palette */
.services-chips .chip:nth-child(1) > span{color:var(--accent)}
.services-chips .chip:nth-child(2) > span{color:var(--accent-coral)}
.services-chips .chip:nth-child(3) > span{color:var(--accent-green)}
.services-chips .chip:nth-child(4) > span{color:#c9a035}
.services-chips .chip:nth-child(5) > span{color:var(--accent-coral)}
.services-chips .chip:nth-child(6) > span{color:var(--accent-green)}
.services-chips .chip:nth-child(7) > span{color:var(--accent)}
.services-chips .chip:nth-child(8) > span{color:#c9a035}
.services-chips .chip:nth-child(9) > span{color:var(--accent-green)}
.s-web .code-line{stroke-dasharray:40;stroke-dashoffset:40;transition:stroke-dashoffset .6s}
.s-web:hover .code-line-1{stroke-dashoffset:0;transition-delay:.05s}
.s-web:hover .code-line-2{stroke-dashoffset:0;transition-delay:.2s}
.s-web:hover .code-line-3{stroke-dashoffset:0;transition-delay:.35s}
.s-web .code-cursor{fill:var(--text);opacity:0;transition:opacity .2s}
.s-web:hover .code-cursor{opacity:1;animation:blink 1s .6s steps(2) infinite}
@keyframes blink{50%{opacity:0}}
.s-ads .bar{transform-origin:bottom;transform:scaleY(.15);transition:transform .55s cubic-bezier(.4,0,.2,1)}
.s-ads:hover .bar-1{transform:scaleY(.45);transition-delay:.05s}
.s-ads:hover .bar-2{transform:scaleY(.75);transition-delay:.15s}
.s-ads:hover .bar-3{transform:scaleY(1);transition-delay:.25s}
.s-ads .ads-arrow{stroke-dasharray:40;stroke-dashoffset:40;stroke:var(--text);transition:stroke-dashoffset .5s .35s}
.s-ads:hover .ads-arrow{stroke-dashoffset:0}
.s-media .reel{transform-origin:center;transition:transform .7s cubic-bezier(.3,0,.3,1)}
.s-media:hover .reel{transform:rotate(120deg)}
.s-media .play{transform-origin:center;transition:transform .4s}
.s-media:hover .play{transform:scale(1.2)}
.s-maint .gear-main{transform-origin:center;transition:transform .9s cubic-bezier(.3,0,.3,1)}
.s-maint:hover .gear-main{transform:rotate(180deg)}
.s-maint .gear-small{transform-origin:center;transition:transform .9s cubic-bezier(.3,0,.3,1)}
.s-maint:hover .gear-small{transform:rotate(-180deg)}
.s-seo .seo-glass{transform:translate(-6px,6px);transition:transform .5s cubic-bezier(.3,0,.3,1)}
.s-seo:hover .seo-glass{transform:translate(6px,-6px)}
.s-seo .seo-line{stroke-dasharray:50;stroke-dashoffset:50;transition:stroke-dashoffset .5s}
.s-seo:hover .seo-line-1{stroke-dashoffset:0;transition-delay:.1s}
.s-seo:hover .seo-line-2{stroke-dashoffset:0;transition-delay:.2s}
.s-seo:hover .seo-line-3{stroke-dashoffset:0;transition-delay:.3s}
.s-ecom .bag{transform-origin:bottom center;transition:transform .5s var(--ease-spring)}
.s-ecom:hover .bag{transform:translateY(-4px) rotate(-4deg)}
.s-ecom .tag{transform:translateY(-30px);opacity:0;transition:transform .5s .15s,opacity .3s .15s}
.s-ecom:hover .tag{transform:translateY(0);opacity:1}
.s-social .heart{transform-origin:center;transition:transform .4s var(--ease-spring)}
.s-social:hover .heart{transform:scale(1.15)}
.s-social .float{opacity:0;transition:opacity .5s,transform .6s cubic-bezier(.3,0,.3,1)}
.s-social:hover .float-1{opacity:1;transform:translate(8px,-22px);transition-delay:.05s}
.s-social:hover .float-2{opacity:1;transform:translate(-6px,-16px);transition-delay:.15s}
.s-social:hover .float-3{opacity:1;transform:translate(14px,-10px);transition-delay:.25s}
.s-content .layer{transform-origin:bottom left;transition:transform .5s cubic-bezier(.3,0,.3,1)}
.s-content:hover .layer-1{transform:rotate(-6deg) translate(-4px,-2px)}
.s-content:hover .layer-2{transform:rotate(2deg) translate(2px,-2px)}
.s-content:hover .layer-3{transform:rotate(10deg) translate(8px,-4px)}
.s-email .flap{transform-origin:top;transform:rotateX(0);transition:transform .5s cubic-bezier(.3,0,.3,1)}
.s-email:hover .flap{transform:rotateX(-170deg)}
.s-email .at-sign{opacity:0;transform:translateY(6px);transition:opacity .3s .2s,transform .4s .2s}
.s-email:hover .at-sign{opacity:1;transform:translateY(0)}

/* ============= Mobile / touch device fixes for services ============= */
/* On touch devices: kill stuck-hover animations and show icons in a clean static state.
   Without these overrides, tapping a service card triggers :hover and freezes
   mid-animation since touch devices have no "unhover" event. */
@media (hover: none), (pointer: coarse) {
  .service{cursor:default}
  .service:hover::before{opacity:0}
  .service:hover::after{transform:scaleX(0)}
  .service:hover .svc-price{background:rgba(244,241,234,.5);color:var(--text);border-color:var(--rule)}
  .service:hover .svc-arrow{background:transparent;border-color:var(--rule);color:var(--text);transform:none}

  /* Show SVG decorations in their visually-complete state instead of pre-animation state */
  .s-web .code-line{stroke-dashoffset:0}
  .s-web .code-cursor{opacity:.4}
  .s-ads .bar-1{transform:scaleY(.4)}
  .s-ads .bar-2{transform:scaleY(.7)}
  .s-ads .bar-3{transform:scaleY(.95)}
  .s-ads .ads-arrow{stroke-dashoffset:0}
  .s-seo .seo-glass{transform:translate(2px,-2px)}
  .s-seo .seo-line{stroke-dashoffset:0}
  .s-ecom .tag{transform:none;opacity:1}
  .s-social .float-1,.s-social .float-2,.s-social .float-3{opacity:.6;transform:none}
  .s-email .at-sign{opacity:.7;transform:none}

  /* Disable transform-based hover changes that look wrong frozen mid-tap */
  .s-media:hover .reel,
  .s-media:hover .play,
  .s-maint:hover .gear-main,
  .s-maint:hover .gear-small,
  .s-seo:hover .seo-glass,
  .s-ecom:hover .bag,
  .s-social:hover .heart,
  .s-content:hover .layer-1,
  .s-content:hover .layer-2,
  .s-content:hover .layer-3,
  .s-email:hover .flap{transform:none}

  /* Service chips above the grid — same stuck-hover issue */
  .chip:hover{background:var(--paper);color:var(--text);border-color:var(--rule);transform:none;box-shadow:none}
  .chip:hover > span{color:var(--text-muted)}
}

/* Tighten service card layout on phones */
@media (max-width:560px){
  .service{padding:28px 22px 30px;min-height:auto}
  .svc-stage{width:60px;height:60px;margin-bottom:16px}
  .svc-name{font-size:23px}
  .svc-desc{font-size:13.5px;padding-bottom:16px}
  .svc-top{margin-bottom:18px}
  .services-chips{padding:0 0 24px;margin-bottom:32px}
  .chip{padding:8px 13px;font-size:12px}
}

/* Bundles */
.bundles{background:var(--paper-2);color:var(--text);padding:clamp(72px,10vw,120px) var(--gutter);border-top:1px solid var(--rule)}
.bundles-inner{max-width:var(--max);margin:0 auto}
.bundles-head{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:end;margin-bottom:48px}
@media (max-width:880px){.bundles-head{grid-template-columns:1fr;gap:20px}}
.bundles-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
@media (max-width:880px){.bundles-grid{grid-template-columns:1fr}}
.bundle{background:var(--paper);border:1px solid var(--rule);border-radius:var(--radius);padding:28px 26px 24px;display:flex;flex-direction:column;transition:transform .35s var(--ease-out),box-shadow .35s,border-color .35s;position:relative;overflow:hidden}
.bundle::before{content:"";position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(var(--accent-rgb),.08),transparent);transition:left .8s}
.bundle:hover::before{left:100%}
/* Per-tier colored top border */
.bundles-grid .bundle:nth-child(1){border-top:3px solid var(--accent-green)}
.bundles-grid .bundle:nth-child(3){border-top:3px solid var(--accent-coral)}
.bundle:hover{transform:translateY(-8px);box-shadow:0 28px 60px rgba(15,15,16,.12);border-color:var(--ink)}
.bundle-name{font-family:var(--f-display);font-weight:500;font-style:italic;font-size:32px;letter-spacing:-.02em;margin-bottom:4px}
.bundle-sub{font-family:var(--f-mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--text-muted);margin-bottom:18px}
.bundle-price{font-family:var(--f-display);font-weight:400;font-size:44px;line-height:1;letter-spacing:-.03em;margin-bottom:6px}
.bundle-price em{font-style:italic;color:var(--accent-deep)}
/* Per-tier price color: Startup → green, Growth → gold (featured), Premium → coral */
.bundles-grid .bundle:nth-child(1) .bundle-price em{color:var(--accent-green)}
.bundle.featured .bundle-price em{color:var(--accent-gold)}
.bundles-grid .bundle:nth-child(3) .bundle-price em{color:var(--accent-coral)}
.bundle-terms{font-family:var(--f-mono);font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--text-muted);padding-bottom:18px;border-bottom:1px solid var(--rule);margin-bottom:18px}
.bundle-incl{list-style:none;display:flex;flex-direction:column;gap:10px;font-size:14px;margin-bottom:22px;flex:1}
.bundle-incl li{display:flex;gap:10px;align-items:flex-start;color:var(--text)}
.bundle-incl li::before{content:"✓";color:var(--accent-green);flex-shrink:0;font-weight:700;font-size:14px;line-height:1.5}
/* Featured (dark) bundle: keep the green checks but lighter */
.bundle.featured .bundle-incl li{color:var(--text-inv)}
.bundle.featured .bundle-incl li::before{color:#5be090}
.bundle-cta{display:inline-flex;align-items:center;gap:8px;padding:12px 18px;border-radius:999px;background:var(--ink);color:var(--text-inv);font-size:13px;font-weight:600;transition:background .2s,transform .2s,box-shadow .3s;align-self:flex-start}
.bundle-cta:hover{background:var(--ink-3);transform:translateX(4px)}
.bundle-cta span{transition:transform .3s}
.bundle-cta:hover span{transform:translateX(3px)}
/* Per-tier CTA accent: Startup → green, Growth → gold, Premium → coral */
.bundles-grid .bundle:nth-child(1) .bundle-cta{background:var(--accent-green);color:#0e1530}
.bundles-grid .bundle:nth-child(1) .bundle-cta:hover{background:var(--accent-green);box-shadow:0 8px 24px rgba(var(--accent-green-rgb),.5),0 0 18px rgba(var(--accent-green-rgb),.35)}
.bundle.featured .bundle-cta{background:var(--accent-gold);color:#0e1530}
.bundle.featured .bundle-cta:hover{background:var(--accent-gold);box-shadow:0 8px 24px rgba(var(--accent-gold-rgb),.55),0 0 22px rgba(var(--accent-gold-rgb),.4)}
.bundles-grid .bundle:nth-child(3) .bundle-cta{background:var(--accent-coral);color:#0e1530}
.bundles-grid .bundle:nth-child(3) .bundle-cta:hover{background:var(--accent-coral);box-shadow:0 8px 24px rgba(var(--accent-coral-rgb),.5),0 0 18px rgba(var(--accent-coral-rgb),.35)}
.bundle.featured{background:var(--ink);color:var(--text-inv);border-color:var(--ink);position:relative;transform:translateY(-12px);box-shadow:0 20px 50px rgba(15,15,16,.18);overflow:visible}
.bundle.featured:hover{transform:translateY(-20px)}
.bundle.featured::after{content:"★ Most popular ★";position:absolute;top:-14px;right:24px;background:linear-gradient(135deg,var(--accent-gold),#ffb347);color:#0e1530;font-family:var(--f-mono);font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;padding:7px 16px;border-radius:999px;box-shadow:0 6px 18px rgba(var(--accent-gold-rgb),.6),0 0 24px rgba(var(--accent-gold-rgb),.4),0 0 0 1px rgba(0,0,0,.04);white-space:nowrap;z-index:3;animation:popular-pulse 2.4s ease-in-out infinite}
@keyframes popular-pulse{0%,100%{box-shadow:0 6px 18px rgba(var(--accent-gold-rgb),.5),0 0 18px rgba(var(--accent-gold-rgb),.3),0 0 0 1px rgba(0,0,0,.04)}50%{box-shadow:0 6px 22px rgba(var(--accent-gold-rgb),.75),0 0 32px rgba(var(--accent-gold-rgb),.55),0 0 0 1px rgba(0,0,0,.04)}}
.bundle.featured .bundle-sub,.bundle.featured .bundle-terms{color:var(--text-inv-muted)}
.bundle.featured .bundle-incl li{color:var(--text-inv)}
.bundle.featured .bundle-incl li::before{color:var(--accent)}
.bundle.featured .bundle-price em{color:var(--accent)}
.bundle.featured .bundle-terms{border-bottom-color:var(--rule-inv)}
.bundle.featured .bundle-cta{background:var(--accent);color:var(--ink)}
.bundle.featured .bundle-cta:hover{background:#7AA0CC}

/* Stats */
.stats{background:var(--ink);padding:clamp(88px,12vw,150px) var(--gutter);position:relative;overflow:hidden}
.stats::before{content:"";position:absolute;inset:0;background:radial-gradient(900px 500px at 50% 0%,rgba(var(--accent-rgb),.05),transparent 60%);pointer-events:none}
.stats-inner{max-width:var(--max);margin:0 auto;position:relative}
.stats-head{font-family:var(--f-display);font-weight:300;font-size:clamp(40px,6.5vw,84px);line-height:1;letter-spacing:-.03em;max-width:18ch;margin-bottom:88px;color:var(--text-inv)}
.stats-head em{font-style:italic;font-weight:500;color:var(--accent)}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border-top:1px solid var(--rule-inv);padding-top:48px}
.stat{padding:60px 32px 16px 32px;border-right:1px solid var(--rule-inv);position:relative;transition:padding-left .3s}
.stat:first-child{padding-left:0}
.stat:hover{padding-left:40px}
.stat:first-child:hover{padding-left:8px}
.stat:last-child{border-right:none}
.stat-num{font-family:var(--f-display);font-weight:400;font-size:clamp(46px,5.5vw,76px);line-height:1.05;letter-spacing:-.03em;color:var(--text-inv);padding-top:2px}
.stat-num em{font-style:italic;font-weight:500;color:var(--accent)}
/* Per-stat color: money=gold, speed=coral, count=green, partners=blue */
.stats-grid .stat:nth-child(1) .stat-num em{color:var(--accent-gold)}
.stats-grid .stat:nth-child(2) .stat-num em{color:var(--accent-coral)}
.stats-grid .stat:nth-child(3) .stat-num em{color:var(--accent-green)}
.stat-lbl{margin-top:32px;font-size:14px;line-height:1.55;color:var(--text-inv-muted);max-width:22ch}
@media (max-width:880px){.stats-grid{grid-template-columns:repeat(2,1fr);padding-top:16px}.stat{border-bottom:1px solid var(--rule-inv);padding-bottom:32px}.stat:nth-child(2){border-right:none}.stat:nth-child(3),.stat:nth-child(4){padding-top:32px}}

/* Process */
.process{background:var(--paper);color:var(--text);padding:clamp(88px,12vw,150px) var(--gutter);position:relative}
.process-inner{max-width:var(--max);margin:0 auto;position:relative}
.process-head{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:end;margin-bottom:60px}
@media (max-width:880px){.process-head{grid-template-columns:1fr;gap:24px;margin-bottom:40px}}
.process-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border-top:1px solid var(--rule);border-left:1px solid var(--rule);position:relative}
@media (max-width:880px){.process-grid{grid-template-columns:1fr}}
.step{padding:40px 32px 36px;border-right:1px solid var(--rule);border-bottom:1px solid var(--rule);display:flex;flex-direction:column;position:relative;transition:background .35s;overflow:hidden}
.step::after{content:"";position:absolute;top:50%;right:-14px;width:28px;height:28px;border-radius:50%;background:var(--paper);border:1px solid var(--rule);transform:translateY(-50%);z-index:2;background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 12'><path d='M4 2 L8 6 L4 10' stroke='%230F0F10' stroke-width='1.3' fill='none' stroke-linecap='round' stroke-linejoin='round'/></svg>");background-repeat:no-repeat;background-position:center;background-size:12px}
.step:last-child::after{display:none}
@media (max-width:880px){.step::after{top:auto;bottom:-14px;right:50%;transform:translate(50%,0) rotate(90deg)}}
.step:hover{background:var(--paper-2)}
.step-num{font-family:var(--f-mono);font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--text-muted);margin-bottom:22px}
.step-num strong{color:var(--accent-deep);font-weight:500;margin-right:4px}
.steps-grid > div:nth-child(1) .step-num strong{color:var(--accent-coral)}
.steps-grid > div:nth-child(2) .step-num strong{color:var(--accent-gold)}
.steps-grid > div:nth-child(3) .step-num strong{color:var(--accent-green)}
.steps-grid > div:nth-child(4) .step-num strong{color:var(--accent)}
.step-glyph{width:64px;height:64px;margin-bottom:22px;color:var(--text)}
.step-glyph svg{width:100%;height:100%;fill:none;stroke:currentColor;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;transition:transform .5s cubic-bezier(.3,0,.3,1)}
.step:hover .step-glyph svg{transform:scale(1.12) rotate(-5deg)}
.step-name{font-family:var(--f-display);font-weight:400;font-size:38px;line-height:1;letter-spacing:-.02em;margin-bottom:16px;color:var(--text)}
.step-name em{font-style:italic;font-weight:500;color:var(--accent-deep)}
.step-desc{font-size:14.5px;line-height:1.6;color:var(--text-muted)}
.step-desc strong{color:var(--text);font-weight:600}
.process-promise{margin-top:44px;padding:24px 20px;border-top:1px solid var(--rule);border-bottom:1px solid var(--rule);display:flex;justify-content:center;align-items:center;flex-wrap:wrap;gap:10px 22px;font-family:var(--f-mono);font-size:11.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--text)}
.process-promise .sep{color:var(--accent-deep);opacity:.7}

.hero-sub strong{color:var(--text-inv);font-weight:600}
.section-sub strong{color:var(--text);font-weight:600}
.section.dark .section-sub strong,.section-sub.light strong{color:var(--text-inv);font-weight:600}

/* Coverage */
