  <script type="module">
  import * as THREE from 'three';
  import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
  import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';

  const stage = document.getElementById('click-globe-stage');
  const starsBox = document.getElementById('globe-stars-layer');
  if (stage && starsBox) {
    /* ───── Stars + shooting stars (DOM, unchanged) ───── */
    function buildStars(){
      const W=starsBox.clientWidth,H=starsBox.clientHeight;
      if(!W||!H)return;
      starsBox.innerHTML='';
      const layer=(count,size,aMin,aMax)=>{
        const el=document.createElement('div');
        el.className='globe-stars__static';
        el.style.width=el.style.height=size+'px';
        const out=[];
        for(let i=0;i<count;i++){
          const x=Math.floor(Math.random()*W);
          const y=Math.floor(Math.random()*H);
          const a=(aMin+Math.random()*(aMax-aMin)).toFixed(2);
          const blur=size===1?'0':(size/2)+'px';
          out.push(`${x}px ${y}px ${blur} rgba(255,255,255,${a})`);
        }
        el.style.boxShadow=out.join(',');
        return el;
      };
      starsBox.appendChild(layer(220,1,.3,.7));
      starsBox.appendChild(layer(60,2,.5,.9));
      starsBox.appendChild(layer(18,3,.75,1));
      for(let i=0;i<28;i++){
        const t=document.createElement('div');
        t.className='globe-stars__twinkle';
        const size=(1+Math.random()*2).toFixed(1);
        t.style.width=size+'px';t.style.height=size+'px';
        t.style.left=(Math.random()*100).toFixed(1)+'%';
        t.style.top=(Math.random()*100).toFixed(1)+'%';
        t.style.setProperty('--dur',(2+Math.random()*3.5).toFixed(1)+'s');
        t.style.setProperty('--del',(Math.random()*4).toFixed(1)+'s');
        t.style.setProperty('--min',(.1+Math.random()*.3).toFixed(2));
        starsBox.appendChild(t);
      }
    }
    if(starsBox.clientWidth>0)buildStars();else requestAnimationFrame(buildStars);
    let resizeTimer=null;
    new ResizeObserver(()=>{clearTimeout(resizeTimer);resizeTimer=setTimeout(buildStars,250);}).observe(starsBox);
    function shoot(){
      if(document.hidden)return;
      const W=starsBox.clientWidth,H=starsBox.clientHeight;
      if(!W||!H)return;
      const ss=document.createElement('div');
      ss.className='globe-shoot';
      const startX=-120+Math.random()*(W*.3);
      const startY=Math.random()*H*.6;
      const angle=18+Math.random()*28;
      const distance=W+280;
      ss.style.left=startX+'px';ss.style.top=startY+'px';
      ss.style.transform=`rotate(${angle}deg) translateX(0)`;
      starsBox.appendChild(ss);
      ss.animate([
        {transform:`rotate(${angle}deg) translateX(0)`,opacity:0},
        {transform:`rotate(${angle}deg) translateX(${distance*.07}px)`,opacity:1,offset:.07},
        {transform:`rotate(${angle}deg) translateX(${distance*.93}px)`,opacity:1,offset:.93},
        {transform:`rotate(${angle}deg) translateX(${distance}px)`,opacity:0}
      ],{duration:900+Math.random()*1100,easing:'cubic-bezier(0.25, 0.6, 0.85, 0.95)'}).onfinish=()=>ss.remove();
    }
    function shootLoop(){shoot();if(Math.random()<.18)setTimeout(shoot,250+Math.random()*400);setTimeout(shootLoop,2400+Math.random()*4500);}
    setTimeout(shootLoop,1200);

    /* ───── Photoreal Earth (Three.js, replaces globe.gl) ───── */
    const TEX = {
      day: 'https://unpkg.com/three-globe@2.30.0/example/img/earth-blue-marble.jpg',
      bump: 'https://unpkg.com/three-globe@2.30.0/example/img/earth-topology.png',
      water: 'https://unpkg.com/three-globe@2.30.0/example/img/earth-water.png'
    };
    const HQ = { lat: 43.08, lng: -73.78 };
    const loader = new THREE.TextureLoader();

    function latLngToVec3(lat, lng, radius = 1) {
      const phi = (90 - lat) * Math.PI / 180;
      const theta = (lng + 180) * Math.PI / 180;
      return new THREE.Vector3(
        -radius * Math.sin(phi) * Math.cos(theta),
        radius * Math.cos(phi),
        radius * Math.sin(phi) * Math.sin(theta)
      );
    }

    const W0 = stage.clientWidth || 800, H0 = stage.clientHeight || 660;
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(38, W0/H0, 0.1, 100);
    camera.position.set(0, 0, 3.0);

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setSize(W0, H0);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);
    stage.appendChild(renderer.domElement);

    const labelRenderer = new CSS2DRenderer();
    labelRenderer.setSize(W0, H0);
    labelRenderer.domElement.style.position = 'absolute';
    labelRenderer.domElement.style.inset = '0';
    labelRenderer.domElement.style.pointerEvents = 'none';
    stage.appendChild(labelRenderer.domElement);

    const controls = new OrbitControls(camera, renderer.domElement);
    controls.enableZoom = false;
    controls.enablePan = false;
    controls.enableDamping = true;
    controls.dampingFactor = 0.1;
    controls.autoRotate = true;
    controls.autoRotateSpeed = 0.45;

    /* Lighting — sun follows camera so visible side stays lit (Spline-like hero look) */
    const ambient = new THREE.AmbientLight(0xffffff, 0.45);
    scene.add(ambient);
    const sun = new THREE.DirectionalLight(0xffffff, 1.5);
    scene.add(sun);

    /* Earth */
    const earthGroup = new THREE.Group();
    scene.add(earthGroup);
    const earthMat = new THREE.MeshPhongMaterial({
      color: 0x1a3a5a,
      map: loader.load(TEX.day),
      bumpMap: loader.load(TEX.bump),
      bumpScale: 0.04,
      specularMap: loader.load(TEX.water),
      specular: new THREE.Color(0x335577),
      shininess: 14
    });
    earthGroup.add(new THREE.Mesh(new THREE.SphereGeometry(1, 64, 64), earthMat));

    /* Atmosphere — soft blue rim glow (back-side fresnel) */
    const atmoMat = new THREE.ShaderMaterial({
      uniforms: { glowColor: { value: new THREE.Color(0x4f8aff) } },
      vertexShader: `
        varying vec3 vNormal;
        void main() {
          vNormal = normalize(normalMatrix * normal);
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
        }
      `,
      fragmentShader: `
        uniform vec3 glowColor;
        varying vec3 vNormal;
        void main() {
          float i = pow(0.65 - dot(vNormal, vec3(0,0,1)), 2.0) * 1.2;
          gl_FragColor = vec4(glowColor, i);
        }
      `,
      side: THREE.BackSide,
      blending: THREE.AdditiveBlending,
      transparent: true,
      depthWrite: false
    });
    scene.add(new THREE.Mesh(new THREE.SphereGeometry(1.18, 64, 64), atmoMat));

    /* HQ marker (surface dot + halo ring) */
    const hqGroup = new THREE.Group();
    hqGroup.add(new THREE.Mesh(
      new THREE.SphereGeometry(0.014, 16, 16),
      new THREE.MeshBasicMaterial({ color: 0xFFB347 })
    ));
    hqGroup.add(new THREE.Mesh(
      new THREE.RingGeometry(0.022, 0.034, 32),
      new THREE.MeshBasicMaterial({ color: 0xFFB347, side: THREE.DoubleSide, transparent: true, opacity: 0.55 })
    ));
    const hqPos = latLngToVec3(HQ.lat, HQ.lng, 1.001);
    hqGroup.position.copy(hqPos);
    hqGroup.lookAt(0, 0, 0);
    hqGroup.rotateY(Math.PI);
    earthGroup.add(hqGroup);

    /* HQ pill label (HTML overlay tracked via CSS2DRenderer) */
    const labelDiv = document.createElement('div');
    labelDiv.className = 'gpin';
    labelDiv.innerHTML = `
      <div class="gpin__tag"><span class="gpin__pulse"></span><div class="gpin__text"><strong>CLICK HQ</strong><span>Saratoga County, NY</span></div></div>
      <div class="gpin__line"></div>
    `;
    const label = new CSS2DObject(labelDiv);
    label.center.set(0.5, 1.0); /* anchor BOTTOM of element at the 3D point */
    label.position.copy(latLngToVec3(HQ.lat, HQ.lng, 1.0));
    earthGroup.add(label);

    /* Hide pill when HQ rotates around to the back side */
    function updateLabel() {
      const wp = new THREE.Vector3();
      label.getWorldPosition(wp);
      const dirToCam = camera.position.clone().sub(wp).normalize();
      const labelN = wp.clone().normalize();
      const dot = dirToCam.dot(labelN);
      labelDiv.style.opacity = dot > 0.05 ? 1 : 0;
      labelDiv.style.transition = 'opacity .35s';
    }

    /* Resize */
    new ResizeObserver(() => {
      const w = stage.clientWidth, h = stage.clientHeight;
      if (!w || !h) return;
      camera.aspect = w/h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
      labelRenderer.setSize(w, h);
    }).observe(stage);

    /* Animate */
    function tick() {
      requestAnimationFrame(tick);
      controls.update();
      sun.position.copy(camera.position).multiplyScalar(2);
      sun.position.y += 1.0;
      updateLabel();
      renderer.render(scene, camera);
      labelRenderer.render(scene, camera);
    }
    tick();
  }
  </script>

