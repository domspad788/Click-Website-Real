<script>
/* Cursor glow follower */
(function(){
  const glow=document.getElementById('cursorGlow');
  if(window.matchMedia('(pointer:coarse)').matches){glow.style.display='none';return}
  let mx=0,my=0,gx=0,gy=0;
  window.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY});
  function tick(){gx+=(mx-gx)*.12;gy+=(my-gy)*.12;glow.style.transform=`translate(${gx}px,${gy}px) translate(-50%,-50%)`;requestAnimationFrame(tick)}
  tick();
})();

/* Scroll progress */
(function(){
  const bar=document.getElementById('scrollProgress');
  window.addEventListener('scroll',()=>{
    const h=document.documentElement;
    const p=h.scrollTop/(h.scrollHeight-h.clientHeight)*100;
    bar.style.width=p+'%';
  },{passive:true});
})();

/* Nav scroll + theme */
(function(){
  const nav=document.getElementById('nav');
  const onScroll=()=>{
    nav.classList.toggle('scrolled',window.scrollY>30);
    const y=window.scrollY+40;let light=false;
    document.querySelectorAll('section,footer').forEach(s=>{
      const r=s.getBoundingClientRect();const top=r.top+window.scrollY;const bot=top+r.height;
      if(y>=top&&y<bot){
        const cls=s.classList;
        if(cls.contains('services')||cls.contains('work')||cls.contains('partners')||cls.contains('bundles')||cls.contains('process'))light=true;
      }
    });
    nav.classList.toggle('light',light);
  };
  window.addEventListener('scroll',onScroll,{passive:true});
  onScroll();
})();

/* Mobile nav */
(function(){
  const burger=document.getElementById('navBurger'),links=document.getElementById('navLinks');
  if(!burger||!links)return;
  burger.addEventListener('click',()=>{burger.classList.toggle('open');links.classList.toggle('open')});
  document.querySelectorAll('.nav-item[data-dd] > .nav-link').forEach(btn=>{
    btn.addEventListener('click',e=>{
      if(window.matchMedia('(max-width:1020px)').matches){
        e.preventDefault();const item=btn.parentElement;
        document.querySelectorAll('.nav-item.mob-open').forEach(o=>{if(o!==item)o.classList.remove('mob-open')});
        item.classList.toggle('mob-open');
      }
    });
  });
  links.querySelectorAll('a').forEach(a=>{
    a.addEventListener('click',()=>{
      if(window.matchMedia('(max-width:1020px)').matches){burger.classList.remove('open');links.classList.remove('open')}
    });
  });
})();

/* Reveal on scroll */
(function(){
  const io=new IntersectionObserver(entries=>{
    entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}});
  },{threshold:.15,rootMargin:'0px 0px -40px 0px'});
  document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
})();

/* Counter animation — supports data-count and data-grow */
(function(){
  function formatNum(n){return n>=1000?n.toLocaleString():String(n)}
  const counters=document.querySelectorAll('[data-count],[data-grow]');
  const io=new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(!e.isIntersecting)return;
      const el=e.target;
      const target=parseInt(el.dataset.count||el.dataset.grow,10);
      const dur=el.dataset.grow?1800:1400;
      const start=performance.now();
      function step(now){
        const p=Math.min((now-start)/dur,1);
        const eased=1-Math.pow(1-p,3);
        el.textContent=formatNum(Math.round(target*eased));
        if(p<1)requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
      io.unobserve(el);
    });
  },{threshold:.3});
  counters.forEach(c=>io.observe(c));
})();

/* Logo marquee duplicate */
(function(){const t=document.getElementById('logoTrack');if(t)t.innerHTML+=t.innerHTML})();


/* Contact form — AJAX submit to Web3Forms with success state + error fallback */
(function(){
  const form = document.getElementById('contactForm');
  if(!form) return;
  const successBlock = document.getElementById('contactFormSuccess');
  const errorBlock = document.getElementById('contactFormError');
  const submitBtn = form.querySelector('.form-submit-btn');

  form.addEventListener('submit', async function(e){
    e.preventDefault();
    errorBlock.hidden = true;

    // Honeypot — if filled, silently abort (it's a bot)
    if(form.querySelector('[name="botcheck"]').checked) return;

    // Loading state
    submitBtn.setAttribute('data-loading','true');
    submitBtn.disabled = true;

    try {
      const formData = new FormData(form);
      // Append a clean timestamp so the email subject reads readable
      formData.append('submitted_at', new Date().toLocaleString('en-US', { timeZone: 'America/New_York' }) + ' ET');

      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData
      });
      const data = await res.json();

      if(data.success){
        // Hide form, show success block
        form.style.display = 'none';
        successBlock.hidden = false;
        // Smooth scroll up so the success message is visible
        successBlock.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else {
        throw new Error(data.message || 'Submission failed');
      }
    } catch(err){
      console.error('Form submission error:', err);
      errorBlock.hidden = false;
      submitBtn.removeAttribute('data-loading');
      submitBtn.disabled = false;
    }
  });
})();
</script>
<script>
/* ============ CLICK INTRO (drop-in) ============ */
(function(){
  document.body.classList.add('cli-lock');

  var pHost=document.getElementById('cli-particles');
  for(var i=0;i<30;i++){
    var p=document.createElement('div');
    p.className='cli-particle';
    p.style.left=Math.random()*100+'%';
    p.style.bottom='-10px';
    p.style.animationDuration=(10+Math.random()*14)+'s';
    p.style.animationDelay=(Math.random()*12)+'s';
    p.style.opacity=String(.3+Math.random()*.5);
    pHost.appendChild(p);
  }

  var intro=document.getElementById('click-intro');
  var cursor=document.getElementById('cli-cursor');
  var trailPath=document.getElementById('cli-trail-path');
  var trail=document.getElementById('cli-trail');
  var wordmark=document.getElementById('cli-wordmark');
  var iStem=document.getElementById('cli-i-stem');
  var dot=document.getElementById('cli-dot');
  var tagline=document.getElementById('cli-tagline');
  var ripples=['cli-r1','cli-r2','cli-r3'].map(function(id){return document.getElementById(id);});
  var ichars=wordmark.querySelectorAll('.cli-ich');
  var logoWrap=document.getElementById('cli-logo-wrap');
  var skip=document.getElementById('cli-skip');

  function dismiss(){
    intro.classList.add('cli-done');
    document.body.classList.remove('cli-lock');
    // Nuke any stale loader/preloader/splash from prior site versions
    ['#intro','#loader','#preloader','#splash','.intro-overlay','.loader','.preloader','.splash','.site-loader','.page-loader'].forEach(function(sel){
      document.querySelectorAll(sel).forEach(function(el){if(el.id!=='click-intro')el.remove();});
    });
    // Also clear common body-lock classes
    document.body.classList.remove('intro-active','loading','no-scroll','locked');
    document.documentElement.classList.remove('intro-active','loading','no-scroll','locked');
    setTimeout(function(){if(intro&&intro.parentNode)intro.parentNode.removeChild(intro);},900);
  }

  function play(){
    iStem.style.visibility='hidden';
    iStem.classList.add('cli-in');
    requestAnimationFrame(function(){
      var wrapRect=logoWrap.getBoundingClientRect();
      var dotRect=dot.getBoundingClientRect();
      var target={x:dotRect.left-wrapRect.left+dotRect.width/2,y:dotRect.top-wrapRect.top+dotRect.height/2};
      iStem.classList.remove('cli-in');
      iStem.style.visibility='';

      var startX=target.x+480, startY=target.y-40;
      var endX=target.x-9, endY=target.y-9;
      cursor.style.transition='none';
      cursor.style.left=startX+'px';
      cursor.style.top=startY+'px';
      cursor.style.transform='';

      var tipStartX=startX+9, tipStartY=startY+9, tipEndX=endX+9, tipEndY=endY+9;
      var ctrl1X=tipStartX-100, ctrl1Y=tipStartY-30, ctrl2X=tipEndX+100, ctrl2Y=tipEndY-50;
      trailPath.setAttribute('d','M '+tipStartX+' '+tipStartY+' C '+ctrl1X+' '+ctrl1Y+', '+ctrl2X+' '+ctrl2Y+', '+tipEndX+' '+tipEndY);
      trail.setAttribute('viewBox','0 0 '+wrapRect.width+' '+wrapRect.height);
      trail.style.width=wrapRect.width+'px';
      trail.style.height=wrapRect.height+'px';

      requestAnimationFrame(function(){
        cursor.style.transition='';
        cursor.classList.add('cli-in');
        trailPath.classList.add('cli-draw');
        cursor.style.left=endX+'px';
        cursor.style.top=endY+'px';
      });

      setTimeout(function(){cursor.classList.add('cli-morph');dot.classList.add('cli-in');iStem.classList.add('cli-in');ripples.forEach(function(r){r.classList.add('cli-go');});},1050);
      setTimeout(function(){ichars.forEach(function(c,idx){setTimeout(function(){c.classList.add('cli-in');},idx*70);});},1200);
      setTimeout(function(){wordmark.classList.add('cli-glow');},1700);
      setTimeout(function(){tagline.classList.add('cli-in');},2200);
      setTimeout(dismiss,4000);
    });
  }

  skip.addEventListener('click',dismiss);

  if(document.readyState==='complete'||document.readyState==='interactive'){
    setTimeout(play,300);
  }else{
    window.addEventListener('DOMContentLoaded',function(){setTimeout(play,300);});
  }
})();
/* ============ END CLICK INTRO ============ */
</script>
